<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net8.0-windows</TargetFramework>
        <Nullable>enable</Nullable>
        <UseWindowsForms>true</UseWindowsForms>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="log4net" Version="3.3.0" />
      <PackageReference Include="MySql.Data" Version="9.6.0" />
      <PackageReference Include="System.Configuration.ConfigurationManager" Version="11.0.0-preview.2.26159.112" />
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Resources\Views\LoginView.cs">
        <SubType>Form</SubType>
      </Compile>
      <Compile Update="Resources\Views\MainView.cs">
        <SubType>Form</SubType>
      </Compile>
    </ItemGroup>

</Project>
